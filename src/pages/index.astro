---
import Base from '../layouts/Base.astro';
import ServiceCard from '../components/ServiceCard.astro';
import CTABand from '../components/CTABand.astro';
import Icon from '../components/Icon.astro';
import { services, site } from '../data/site';

const steps = [
  { n: '01', t: 'Assess', d: 'We map your current state against the relevant frameworks.' },
  { n: '02', t: 'Plan', d: 'You get a clear, prioritized roadmap with effort and impact.' },
  { n: '03', t: 'Implement', d: 'We help put the policies, controls and evidence in place.' },
  { n: '04', t: 'Operate', d: 'Ongoing support to stay compliant and resilient as you grow.' },
];

const why = [
  { t: 'Independent advice, not a product pitch', d: 'We don’t resell tools — our only job is your security and compliance.' },
  { t: 'We implement, not just advise', d: 'Reports are easy. We stay until controls are actually in place.' },
  { t: 'Right-sized expertise', d: 'Senior help, scaled to what you need this month — no over-hiring.' },
  { t: 'EU-native', d: 'We live and breathe NIS2, GDPR, ISO 27001 and DORA in a European context.' },
];
---

<Base
  title="CyberCap — Cybersecurity & Compliance Advisory (NIS2, ISO 27001, GDPR)"
  description="Practical cybersecurity and compliance support for European businesses. Assessments, implementation and ongoing expertise for NIS2, GDPR, ISO 27001 and DORA."
>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-ink">
    <div class="absolute inset-0 opacity-[0.07]" aria-hidden="true"
      style="background-image: radial-gradient(circle at 1px 1px, #ffffff 1px, transparent 0); background-size: 28px 28px;"></div>
    <div class="container-c relative grid gap-12 py-20 lg:grid-cols-2 lg:py-28">
      <div>
        <p class="eyebrow">Cybersecurity & compliance, simplified</p>
        <h1 class="h1 mt-4 text-white">Compliance and security, made manageable.</h1>
        <p class="mt-6 max-w-xl text-lg leading-relaxed text-white/75">
          We help European businesses meet NIS2, GDPR, ISO 27001 and DORA requirements — and stay there —
          without building a full in-house security team. Practical advice, hands-on implementation, and expertise when you need it.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/contact" class="btn-primary">Book a free consult</a>
          <a href="#how" class="btn-ghost-light">See how we work</a>
        </div>
      </div>
      <div class="flex items-center">
        <div class="grid w-full grid-cols-2 gap-4">
          {site.frameworks.map((f) => (
            <div class="rounded-xl border border-white/10 bg-white/[0.04] px-4 py-5 text-center">
              <span class="font-semibold text-white">{f}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Trust strip -->
  <section class="border-b border-cloud bg-mist">
    <div class="container-c py-8 text-center">
      <p class="text-sm font-medium text-slate">
        Trusted by companies in <span class="text-ink">{site.sectors.join(' · ')}</span>
      </p>
    </div>
  </section>

  <!-- Pillars -->
  <section class="container-c py-20">
    <div class="mx-auto max-w-2xl text-center">
      <p class="eyebrow">What we do</p>
      <h2 class="h2 mt-3">One partner, three ways we help</h2>
    </div>
    <div class="mt-12 grid gap-6 md:grid-cols-3">
      {services.map((s) => <ServiceCard {...s} />)}
    </div>
  </section>

  <!-- Why -->
  <section class="bg-mist">
    <div class="container-c py-20">
      <div class="mx-auto max-w-2xl text-center">
        <p class="eyebrow">Why CyberCap</p>
        <h2 class="h2 mt-3">A different kind of security partner</h2>
      </div>
      <div class="mt-12 grid gap-6 sm:grid-cols-2">
        {why.map((w) => (
          <div class="flex gap-4 rounded-2xl bg-white p-6">
            <span class="mt-1 flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-teal/10 text-teal">
              <Icon name="check" class="h-5 w-5" />
            </span>
            <div>
              <h3 class="font-bold text-ink">{w.t}</h3>
              <p class="mt-1 text-slate">{w.d}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How we work -->
  <section id="how" class="container-c py-20">
    <div class="mx-auto max-w-2xl text-center">
      <p class="eyebrow">How we work</p>
      <h2 class="h2 mt-3">A simple, predictable path</h2>
      <p class="mt-4 text-lg text-slate">From “where do we start?” to “we’ve got this.”</p>
    </div>
    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {steps.map((s) => (
        <div class="rounded-2xl border border-cloud p-6">
          <span class="text-2xl font-extrabold text-teal">{s.n}</span>
          <h3 class="mt-2 text-lg font-bold text-ink">{s.t}</h3>
          <p class="mt-2 text-slate">{s.d}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Proof -->
  <section class="bg-mist">
    <div class="container-c py-20">
      <div class="mx-auto max-w-2xl text-center">
        <p class="eyebrow">Proof</p>
        <h2 class="h2 mt-3">Real engagements, real outcomes</h2>
      </div>
      <div class="mt-12 grid gap-6 md:grid-cols-2">
        {[
          'Guided an aviation software company through an ISO 9001 / ISO 27001 management system aligned to international aviation requirements.',
          'Acting DORA programme lead for a fintech, preparing for national-regulator (NBB) deadlines.',
          'Delivered a NIS2 compliance programme for a managed-services / telecom provider.',
          'CISO-as-a-Service for an insurance & benefits organization.',
        ].map((p) => (
          <div class="rounded-2xl bg-white p-6 text-ink">
            <Icon name="check" class="h-5 w-5 text-teal" />
            <p class="mt-3 text-slate">{p}</p>
          </div>
        ))}
      </div>
      <p class="mt-6 text-center text-sm text-slate">Client names shown by sector to respect confidentiality. References available on request.</p>
    </div>
  </section>

  <CTABand />
</Base>
