---
import Base from '../layouts/Base.astro';
---
<Base title="Page not found | CyberCap" description="The page you’re looking for doesn’t exist.">
  <section class="container-c flex min-h-[50vh] flex-col items-center justify-center py-20 text-center">
    <p class="eyebrow">404</p>
    <h1 class="h1 mt-3">This page wandered off.</h1>
    <p class="mt-4 max-w-md text-lg text-slate">The page you’re looking for doesn’t exist or has moved.</p>
    <a href="/" class="btn-primary mt-8">Back to home</a>
  </section>
</Base>
