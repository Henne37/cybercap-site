---
import { site, nav, services } from '../data/site';
const year = new Date().getFullYear();
---

<footer class="mt-24 bg-ink text-white/80">
  <div class="container-c grid gap-10 py-14 sm:grid-cols-2 lg:grid-cols-4">
    <div class="lg:col-span-1">
      <img src="/brand/logo-full-inverse.svg" alt={site.name} class="h-9 w-auto" />
      <p class="mt-4 max-w-xs text-sm leading-relaxed">{site.tagline}</p>
      <p class="mt-4 text-sm font-medium text-white">{site.frameworks.join(' · ')}</p>
    </div>

    <div>
      <h3 class="text-sm font-semibold uppercase tracking-wider text-white/60">Services</h3>
      <ul class="mt-4 space-y-2 text-sm">
        {services.map((s) => (
          <li><a href={`/services/${s.slug}`} class="hover:text-white">{s.title}</a></li>
        ))}
      </ul>
    </div>

    <div>
      <h3 class="text-sm font-semibold uppercase tracking-wider text-white/60">Company</h3>
      <ul class="mt-4 space-y-2 text-sm">
        {nav.map((item) => (
          <li><a href={item.href} class="hover:text-white">{item.label}</a></li>
        ))}
      </ul>
    </div>

    <div>
      <h3 class="text-sm font-semibold uppercase tracking-wider text-white/60">Get in touch</h3>
      <ul class="mt-4 space-y-2 text-sm">
        <li><a href={`mailto:${site.email}`} class="hover:text-white">{site.email}</a></li>
        <li>{site.address}</li>
        <li class="text-white/50">VAT {site.vat}</li>
      </ul>
    </div>
  </div>

  <div class="border-t border-white/10">
    <div class="container-c flex flex-col items-center justify-between gap-3 py-6 text-xs text-white/50 sm:flex-row">
      <p>© {year} {site.name}. All rights reserved.</p>
      <div class="flex gap-5">
        <a href="/privacy" class="hover:text-white">Privacy</a>
        <a href="/cookies" class="hover:text-white">Cookies</a>
        <a href="/terms" class="hover:text-white">Terms</a>
      </div>
    </div>
  </div>
</footer>
