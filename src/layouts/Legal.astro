---
import Base from './Base.astro';
interface Props { title: string; description: string; heading: string; updated: string; }
const { title, description, heading, updated } = Astro.props;
---
<Base title={title} description={description}>
  <section class="bg-mist">
    <div class="container-c py-14">
      <h1 class="h2">{heading}</h1>
      <p class="mt-3 text-sm text-slate">Last updated: {updated}</p>
    </div>
  </section>
  <article class="legal container-c max-w-3xl py-14">
    <slot />
  </article>
</Base>
